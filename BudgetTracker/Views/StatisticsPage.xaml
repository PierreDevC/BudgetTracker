<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BudgetTracker.ViewModels"
             x:Class="BudgetTracker.Views.StatisticsPage"
             BackgroundColor="#F2F1EB"
             Shell.NavBarIsVisible="False"
             Title="Statistiques">

    <Grid>
        <Grid RowDefinitions="Auto,*">
            <!-- Rounded Header -->
            <Border Grid.Row="0" Style="{StaticResource PageHeader}">
                <Label Text="Statistiques" Style="{StaticResource PageHeaderTitle}" />
            </Border>

            <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                <Label Text="En développement" FontSize="20" FontFamily="MerriweatherBold"
                       TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" />
                <Label Text="Cette fonctionnalité sera disponible prochainement."
                       FontSize="14" TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
