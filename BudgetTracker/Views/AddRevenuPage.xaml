<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetTracker.Views.AddRevenuPage"
             BackgroundColor="#F2F1EB"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="24,16">

        <!-- Handle + Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="16">
            <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2"
                     BackgroundColor="#CCCCCC" HorizontalOptions="Center" Margin="0,4,0,0" />
            <Label Text="Nouveau revenu" FontSize="20" FontFamily="MerriweatherBold"
                   TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Form -->
        <ScrollView Grid.Row="1" Margin="0,20,0,0">
            <VerticalStackLayout Spacing="16">

                <!-- Source -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Source" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0.5" Stroke="#AAAAAA"
                            BackgroundColor="White" Padding="16,0">
                        <Entry Text="{Binding Name}" Placeholder="Ex: Salaire"
                               PlaceholderColor="#AAAAAA" BackgroundColor="Transparent" />
                    </Border>
                </VerticalStackLayout>

                <!-- Montant -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Montant ($)" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0.5" Stroke="#AAAAAA"
                            BackgroundColor="White" Padding="16,0">
                        <Entry Text="{Binding AmountText}" Placeholder="0.00"
                               PlaceholderColor="#AAAAAA" BackgroundColor="Transparent"
                               Keyboard="Numeric" />
                    </Border>
                </VerticalStackLayout>

                <!-- Date -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Date" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0.5" Stroke="#AAAAAA"
                            BackgroundColor="White" Padding="16,4">
                        <DatePicker Date="{Binding Date}" Format="d MMMM yyyy" />
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Actions -->
        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,16,0,24">
            <Button Text="Sauvegarder" Command="{Binding SaveCommand}"
                    BackgroundColor="#134016" TextColor="White" FontFamily="InterBold"
                    FontSize="16" CornerRadius="25"
                    HeightRequest="52" />
            <Button Text="Annuler" Command="{Binding CancelCommand}"
                    BackgroundColor="Transparent" TextColor="#134016"
                    BorderColor="#134016" BorderWidth="1.5" FontFamily="InterBold"
                    FontSize="16" CornerRadius="25"
                    HeightRequest="52" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
