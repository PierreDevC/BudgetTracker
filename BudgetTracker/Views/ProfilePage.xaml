<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="BudgetTracker.Views.ProfilePage"
             BackgroundColor="{StaticResource Background}"
             Title="Profil">

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="16">

            <!-- Avatar -->
            <Frame WidthRequest="80" HeightRequest="80" CornerRadius="40"
                   BackgroundColor="{StaticResource Primary}" Padding="0"
                   HorizontalOptions="Center" HasShadow="False" Margin="0,20,0,0">
                <Label FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"
                       Text="{mi:FluentFilled Icon=Person24Filled}" TextColor="White" />
            </Frame>

            <Label Text="Mon Profil" Style="{StaticResource PageTitle}" HorizontalOptions="Center" />

            <!-- Form -->
            <Frame Style="{StaticResource CardFrame}" Padding="20">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Nom" FontAttributes="Bold" />
                    <Entry Text="{Binding Name}" Placeholder="Votre nom" />

                    <Label Text="Courriel" FontAttributes="Bold" />
                    <Entry Text="{Binding Email}" Placeholder="Courriel" Keyboard="Email" />

                    <Label Text="Objectif" FontAttributes="Bold" />
                    <Entry Text="{Binding Goal}" Placeholder="Votre but financier" />

                    <Label Text="Raison" FontAttributes="Bold" />
                    <Entry Text="{Binding Reason}" Placeholder="Pourquoi BudgetTracker?" />
                </VerticalStackLayout>
            </Frame>

            <!-- Settings section -->
            <Label Text="Paramètres" Style="{StaticResource SectionTitle}" Margin="0,8,0,0" />
            <Frame Style="{StaticResource CardFrame}" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Grid.Column="0" FontSize="20" TextColor="{StaticResource Primary}" VerticalOptions="Center"
                               Text="{mi:FluentFilled Icon=Alert24Filled}" />
                        <Label Grid.Column="1" Text="Notifications" VerticalOptions="Center" />
                        <Switch Grid.Column="2" IsToggled="True" OnColor="{StaticResource Primary}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#E0E0E0" />
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Grid.Column="0" FontSize="20" TextColor="{StaticResource Primary}" VerticalOptions="Center"
                               Text="{mi:FluentFilled Icon=WeatherMoon24Filled}" />
                        <Label Grid.Column="1" Text="Mode sombre" VerticalOptions="Center" />
                        <Switch Grid.Column="2" IsToggled="False" OnColor="{StaticResource Primary}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#E0E0E0" />
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Label Grid.Column="0" FontSize="20" TextColor="{StaticResource Primary}" VerticalOptions="Center"
                               Text="{mi:FluentFilled Icon=Money24Filled}" />
                        <Label Grid.Column="1" Text="Devise" VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="CAD $" TextColor="{StaticResource TextSecondary}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Sauvegarder" BackgroundColor="#134016" TextColor="White"
                    FontFamily="InterBold" FontSize="16"
                    CornerRadius="{OnPlatform iOS=25, Android=25, Default=40}"
                    HeightRequest="52" Command="{Binding SaveCommand}" />

            <Button Text="Déconnexion" BackgroundColor="{StaticResource ExpenseRed}" TextColor="White"
                    FontFamily="InterBold" FontSize="16"
                    CornerRadius="{OnPlatform iOS=25, Android=25, Default=40}"
                    HeightRequest="52" Command="{Binding LogoutCommand}" Margin="0,0,0,30" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>