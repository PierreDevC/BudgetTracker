<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="BudgetTracker.Views.ProfilePage"
             BackgroundColor="{StaticResource Background}"
             Title="Profil">

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="16">

            <!-- Avatar -->
            <Frame WidthRequest="80" HeightRequest="80" CornerRadius="40"
                   BackgroundColor="{StaticResource Primary}" Padding="0"
                   HorizontalOptions="Center" HasShadow="False" Margin="0,20,0,0">
                <Label FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"
                       Text="{mi:FluentFilled Icon=Person24Filled}" TextColor="White" />
            </Frame>

            <Label Text="Mon Profil" Style="{StaticResource PageTitle}" HorizontalOptions="Center" />

            <!-- Form -->
            <Frame Style="{StaticResource CardFrame}" Padding="20">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Nom" FontAttributes="Bold" />
                    <Entry Text="{Binding Name}" Placeholder="Votre nom" />

                    <Label Text="Courriel" FontAttributes="Bold" />
                    <Entry Text="{Binding Email}" Placeholder="Courriel" Keyboard="Email" IsEnabled="False" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Sauvegarder" BackgroundColor="#134016" TextColor="White"
                    FontFamily="InterBold" FontSize="16"
                    CornerRadius="{OnPlatform iOS=25, Android=25, Default=40}"
                    HeightRequest="52" Command="{Binding SaveCommand}" />

            <!-- Change password -->
            <Label Text="Mot de passe" Style="{StaticResource SectionTitle}" Margin="0,8,0,0" />
            <Frame Style="{StaticResource CardFrame}" Padding="20">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Mot de passe actuel" FontAttributes="Bold" />
                    <Entry Text="{Binding CurrentPassword}" Placeholder="••••••••" IsPassword="True" />

                    <Label Text="Nouveau mot de passe" FontAttributes="Bold" />
                    <Entry Text="{Binding NewPassword}" Placeholder="••••••••" IsPassword="True" />

                    <Label Text="Confirmer le mot de passe" FontAttributes="Bold" />
                    <Entry Text="{Binding ConfirmNewPassword}" Placeholder="••••••••" IsPassword="True" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Changer le mot de passe" BackgroundColor="#134016" TextColor="White"
                    FontFamily="InterBold" FontSize="16"
                    CornerRadius="{OnPlatform iOS=25, Android=25, Default=40}"
                    HeightRequest="52" Command="{Binding ChangePasswordCommand}" />

            <Button Text="Déconnexion" BackgroundColor="{StaticResource ExpenseRed}" TextColor="White"
                    FontFamily="InterBold" FontSize="16"
                    CornerRadius="{OnPlatform iOS=25, Android=25, Default=40}"
                    HeightRequest="52" Command="{Binding LogoutCommand}" Margin="0,0,0,30" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>