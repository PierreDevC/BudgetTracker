<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="BudgetTracker.Views.ProfilePage"
             BackgroundColor="#F2F1EB"
             Title="Profil">

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="16">

            <!-- Avatar -->
            <Border WidthRequest="80" HeightRequest="80"
                    StrokeShape="RoundRectangle 40"
                    BackgroundColor="#134016"
                    StrokeThickness="0"
                    HorizontalOptions="Center"
                    Margin="0,20,0,0">
                <Label FontSize="36" HorizontalOptions="Center" VerticalOptions="Center"
                       Text="{mi:FluentFilled Icon=Person24Filled}" TextColor="White" />
            </Border>

            <Label Text="Mon Profil" Style="{StaticResource PageTitle}" HorizontalOptions="Center" />

            <!-- Profile Info Card -->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                    StrokeThickness="0.5" Stroke="#AAAAAA" Padding="20">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Nom" FontAttributes="Bold" TextColor="Black" />
                    <Border StrokeShape="RoundRectangle 40" StrokeThickness="0.5"
                            Stroke="#AAAAAA" BackgroundColor="White" Padding="16,0">
                        <Entry Text="{Binding Name}" Placeholder="Votre nom"
                               TextColor="Black" PlaceholderColor="#AAAAAA"
                               BackgroundColor="Transparent" />
                    </Border>

                    <Label Text="Courriel" FontAttributes="Bold" TextColor="Black" />
                    <Border StrokeShape="RoundRectangle 40" StrokeThickness="0.5"
                            Stroke="#AAAAAA" BackgroundColor="#F5F5F5" Padding="16,0">
                        <Entry Text="{Binding Email}" Placeholder="Courriel" Keyboard="Email"
                               IsEnabled="False" TextColor="#888888"
                               PlaceholderColor="#AAAAAA" BackgroundColor="Transparent" />
                    </Border>

                </VerticalStackLayout>
            </Border>

            <Button Text="Sauvegarder" BackgroundColor="#134016" TextColor="White"
                    FontFamily="InterBold" FontSize="16"
                    CornerRadius="25" HeightRequest="52"
                    Command="{Binding SaveCommand}" />

            <!-- Password Section -->
            <Label Text="Changer mot de passe" Style="{StaticResource SectionTitle}" Margin="0,10,0,0" />

            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16"
                    StrokeThickness="0.5" Stroke="#AAAAAA" Padding="20">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Mot de passe actuel" FontAttributes="Bold" TextColor="Black" />
                    <Border StrokeShape="RoundRectangle 40" StrokeThickness="0.5"
                            Stroke="#AAAAAA" BackgroundColor="White" Padding="16,0">
                        <Entry Text="{Binding CurrentPassword}" Placeholder="••••••••" IsPassword="True"
                               TextColor="Black" PlaceholderColor="#AAAAAA"
                               BackgroundColor="Transparent" />
                    </Border>

                    <Label Text="Nouveau mot de passe" FontAttributes="Bold" TextColor="Black" />
                    <Border StrokeShape="RoundRectangle 40" StrokeThickness="0.5"
                            Stroke="#AAAAAA" BackgroundColor="White" Padding="16,0">
                        <Entry Text="{Binding NewPassword}" Placeholder="••••••••" IsPassword="True"
                               TextColor="Black" PlaceholderColor="#AAAAAA"
                               BackgroundColor="Transparent" />
                    </Border>

                    <Label Text="Confirmer le mot de passe" FontAttributes="Bold" TextColor="Black" />
                    <Border StrokeShape="RoundRectangle 40" StrokeThickness="0.5"
                            Stroke="#AAAAAA" BackgroundColor="White" Padding="16,0">
                        <Entry Text="{Binding ConfirmNewPassword}" Placeholder="••••••••" IsPassword="True"
                               TextColor="Black" PlaceholderColor="#AAAAAA"
                               BackgroundColor="Transparent" />
                    </Border>

                </VerticalStackLayout>
            </Border>

            <Button Text="Changer le mot de passe" BackgroundColor="#134016" TextColor="White"
                    FontFamily="InterBold" FontSize="16"
                    CornerRadius="25" HeightRequest="52"
                    Command="{Binding ChangePasswordCommand}" />

            <Button Text="Déconnexion" BackgroundColor="#FF7675" TextColor="White"
                    FontFamily="InterBold" FontSize="16"
                    CornerRadius="25" HeightRequest="52"
                    Command="{Binding LogoutCommand}" Margin="0,0,0,30" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
