<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BudgetTracker.Models"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             x:Class="BudgetTracker.Views.TransactionsPage"
             BackgroundColor="#F2F1EB"
             Shell.NavBarIsVisible="False"
             Title="Transactions">

    <Grid>
        <Grid RowDefinitions="Auto,Auto,*">
            <!-- Rounded Header -->
            <Border Grid.Row="0" Style="{StaticResource PageHeader}">
                <Label Text="Transactions" Style="{StaticResource PageHeaderTitle}" />
            </Border>

            <!-- Search Bar -->
            <Border Grid.Row="1" 
                    Margin="20,12,20,8"
                    StrokeShape="RoundRectangle 40"
                    StrokeThickness="0.5"
                    Stroke="#AAAAAA"
                    BackgroundColor="White"
                    Padding="16,0">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Grid.Column="0" 
                           VerticalOptions="Center" 
                           FontSize="18" 
                           TextColor="#AAAAAA"
                           Text="{mi:FluentFilled Icon=Search24Filled}" />
                    <Entry Grid.Column="1"
                           Placeholder="Rechercher par nom, catégorie ou montant..."
                           PlaceholderColor="#AAAAAA"
                           TextColor="Black"
                           BackgroundColor="Transparent"
                           Text="{Binding SearchText}" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" Padding="20,0,20,0">
                <CollectionView x:Name="TransactionsList"
                                ItemsSource="{Binding Transactions}" 
                                SelectionMode="None"
                                Scrolled="OnScrolled">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Transaction">
                            <Border BackgroundColor="White"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="0.5"
                                    Stroke="#AAAAAA"
                                    Margin="0,0,0,10" 
                                    Padding="14">
                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto" ColumnSpacing="12">

                                    <!-- Icon circle -->
                                    <Border Grid.RowSpan="2" WidthRequest="40" HeightRequest="40" 
                                            StrokeShape="RoundRectangle 20"
                                            Padding="0" BackgroundColor="#F2F1EB" StrokeThickness="0"
                                            VerticalOptions="Center">
                                        <Label Text="💳" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>

                                    <!-- Name + category -->
                                    <Label Grid.Column="1" Grid.Row="0" Text="{Binding Name}"
                                           FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                                    <Label Grid.Column="1" Grid.Row="1"
                                           TextColor="{StaticResource TextSecondary}" FontSize="12">
                                        <Label.Text>
                                            <MultiBinding StringFormat="{}{0} • {1:d MMM yyyy}">
                                                <Binding Path="Category" />
                                                <Binding Path="Date" />
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>

                                    <!-- Amount -->
                                    <Label Grid.Column="2" Grid.RowSpan="2" Text="{Binding DisplayAmount}"
                                           FontSize="16" FontAttributes="Bold"
                                           TextColor="{Binding AmountColor}"
                                           VerticalOptions="Center" HorizontalOptions="End" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                            <Label Text="Aucune transaction trouvée" FontSize="20" FontFamily="MerriweatherBold"
                                   TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" />
                            <Label Text="Essayez une autre recherche."
                                   FontSize="14" TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>
            </Grid>
        </Grid>

        <!-- FAB -->
        <Button x:Name="FabButton"
                Text="+ Transaction" 
                FontSize="15"
                FontAttributes="Bold"
                BackgroundColor="#134016"
                TextColor="White"
                CornerRadius="28"
                HeightRequest="56"
                Padding="20,0"
                HorizontalOptions="End" 
                VerticalOptions="End" 
                Margin="0,0,20,30"
                Command="{Binding AddTransactionCommand}" />
    </Grid>
</ContentPage>