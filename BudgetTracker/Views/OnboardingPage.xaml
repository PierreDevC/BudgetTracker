<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BudgetTracker.ViewModels"
             x:Class="BudgetTracker.Views.OnboardingPage"
             BackgroundColor="#F2F1EB"
             NavigationPage.HasNavigationBar="False">

    <Grid Padding="24" RowDefinitions="Auto,*,Auto">

        <!-- Progress dots -->
        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Center" Spacing="8" Margin="0,40,0,20">
            <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                     BackgroundColor="#134016" Opacity="{Binding Dot0Opacity}" />
            <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                     BackgroundColor="#134016" Opacity="{Binding Dot1Opacity}" />
            <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                     BackgroundColor="#134016" Opacity="{Binding Dot2Opacity}" />
            <BoxView WidthRequest="10" HeightRequest="10" CornerRadius="5"
                     BackgroundColor="#134016" Opacity="{Binding Dot3Opacity}" />
        </HorizontalStackLayout>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12">

                <!-- Step 0: Bienvenue -->
                <VerticalStackLayout IsVisible="{Binding IsStep0}" Spacing="16" VerticalOptions="Center" Margin="0,40,0,0">
                    <Label Text="Bienvenue! 👋"
                           Style="{StaticResource PageTitle}"
                           HorizontalOptions="Center" />
                    <Label Text="Prenez le contrôle de vos finances grâce à un suivi simple et intuitif. Commençons par configurer votre profil en quelques étapes rapides."
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <!-- Step 1: Vos Revenus -->
                <VerticalStackLayout IsVisible="{Binding IsStep1}" Spacing="14">
                    <Label Text="Vos Revenus"
                           Style="{StaticResource PageTitle}"
                           HorizontalOptions="Start" />
                    <Label Text="Entrez votre revenu mensuel principal pour établir une base de référence pour votre budget."
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           Margin="0,0,0,8" />

                    <Label Text="Revenu mensuel ($)"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Border StrokeShape="RoundRectangle 12"
                            StrokeThickness="0.5"
                            Stroke="#AAAAAA"
                            BackgroundColor="White"
                            Padding="16,0">
                        <Entry Placeholder="ex: 3500"
                               Text="{Binding MonthlyIncome}"
                               TextColor="Black"
                               PlaceholderColor="#AAAAAA"
                               BackgroundColor="Transparent"
                               Keyboard="Numeric" />
                    </Border>
                </VerticalStackLayout>

                <!-- Step 2: Vos Budgets -->
                <VerticalStackLayout IsVisible="{Binding IsStep2}" Spacing="14">
                    <Label Text="Vos Budgets"
                           Style="{StaticResource PageTitle}"
                           HorizontalOptions="Start" />
                    <Label Text="Définissons vos 3 catégories de dépenses essentielles."
                           FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           Margin="0,0,0,8" />

                    <!-- Épicerie -->
                    <Label Text="🛒 Épicerie ($)"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Border StrokeShape="RoundRectangle 12"
                            StrokeThickness="0.5"
                            Stroke="#AAAAAA"
                            BackgroundColor="White"
                            Padding="16,0">
                        <Entry Placeholder="ex: 400"
                               Text="{Binding GroceriesBudget}"
                               TextColor="Black"
                               PlaceholderColor="#AAAAAA"
                               BackgroundColor="Transparent"
                               Keyboard="Numeric" />
                    </Border>

                    <!-- Loyer -->
                    <Label Text="🏠 Loyer ou Hypothèque ($)"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Border StrokeShape="RoundRectangle 12"
                            StrokeThickness="0.5"
                            Stroke="#AAAAAA"
                            BackgroundColor="White"
                            Padding="16,0">
                        <Entry Placeholder="ex: 1200"
                               Text="{Binding RentBudget}"
                               TextColor="Black"
                               PlaceholderColor="#AAAAAA"
                               BackgroundColor="Transparent"
                               Keyboard="Numeric" />
                    </Border>

                    <!-- Transport -->
                    <Label Text="🚗 Transport ($)"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Border StrokeShape="RoundRectangle 12"
                            StrokeThickness="0.5"
                            Stroke="#AAAAAA"
                            BackgroundColor="White"
                            Padding="16,0">
                        <Entry Placeholder="ex: 150"
                               Text="{Binding TransportBudget}"
                               TextColor="Black"
                               PlaceholderColor="#AAAAAA"
                               BackgroundColor="Transparent"
                               Keyboard="Numeric" />
                    </Border>
                </VerticalStackLayout>

                <!-- Step 3: Suivi & Statistiques -->
                <VerticalStackLayout IsVisible="{Binding IsStep3}" Spacing="16" VerticalOptions="Center" Margin="0,40,0,0">
                    <Label Text="Suivi &amp; Statistiques"
                           Style="{StaticResource PageTitle}"
                           HorizontalOptions="Center" />
                    <Label Text="📊" FontSize="64" HorizontalOptions="Center" />
                    <Label Text="Vous pourrez ajouter vos dépenses quotidiennes et consulter vos statistiques pour rester sur la bonne voie. Vous êtes prêt!"
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Buttons -->
        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="0,12,0,30">
            <Button Text="Suivant"
                    BackgroundColor="#134016"
                    TextColor="White"
                    FontFamily="InterBold"
                    FontSize="16"
                    CornerRadius="25"
                    HeightRequest="52"
                    IsVisible="{Binding ShowNextButton}"
                    Command="{Binding NextCommand}" />
            <Button Text="Terminer"
                    BackgroundColor="#134016"
                    TextColor="White"
                    FontFamily="InterBold"
                    FontSize="16"
                    CornerRadius="25"
                    HeightRequest="52"
                    IsVisible="{Binding ShowFinishButton}"
                    Command="{Binding FinishCommand}" />
            <Button Text="Retour"
                    BackgroundColor="Transparent"
                    TextColor="#134016"
                    BorderColor="#134016"
                    BorderWidth="1.5"
                    FontFamily="InterBold"
                    FontSize="16"
                    CornerRadius="25"
                    HeightRequest="52"
                    IsVisible="{Binding ShowBackButton}"
                    Command="{Binding BackCommand}" />
            <Button Text="Passer"
                    BackgroundColor="Transparent"
                    TextColor="#134016"
                    BorderColor="#134016"
                    BorderWidth="1.5"
                    FontFamily="InterBold"
                    FontSize="16"
                    CornerRadius="25"
                    HeightRequest="52"
                    IsVisible="{Binding ShowSkipButton}"
                    Command="{Binding SkipCommand}" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>