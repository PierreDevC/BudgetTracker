<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BudgetTracker.Views.SplashPage"
             BackgroundColor="{StaticResource Primary}"
             Shell.NavBarIsVisible="False">

    <Grid VerticalOptions="Center" HorizontalOptions="Center" RowDefinitions="Auto,Auto,Auto">
        <Label Text="💰" FontSize="80" HorizontalOptions="Center" Grid.Row="0" />
        <Label Text="BudgetTracker"
               FontSize="36" FontAttributes="Bold" TextColor="White"
               HorizontalOptions="Center" Grid.Row="1" Margin="0,10,0,0" />
        <Label Text="Gérez vos finances simplement."
               FontSize="16" TextColor="#CCFFFFFF"
               HorizontalOptions="Center" Grid.Row="2" Margin="0,8,0,0" />
        <ActivityIndicator IsRunning="True" Color="White" Grid.Row="2"
                           Margin="0,40,0,0" />
    </Grid>

</ContentPage>