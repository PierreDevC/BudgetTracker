<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BudgetTracker.ViewModels"
             x:Class="BudgetTracker.Views.RegisterPage"
             BackgroundColor="#F2F1EB"
             NavigationPage.HasNavigationBar="False">

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="16" VerticalOptions="Center">

            <Label Text="Créer un compte" Style="{StaticResource PageTitle}"
                   HorizontalOptions="Center" />
            <Label Text="Remplissez vos informations" FontSize="14"
                   TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center"
                   Margin="0,0,0,10" />

            <VerticalStackLayout Spacing="14">

                <Label Text="Nom d'utilisateur" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                <Border StrokeShape="RoundRectangle 40"
                        StrokeThickness="0.5"
                        Stroke="#AAAAAA"
                        BackgroundColor="White"
                        Padding="16,0">
                    <Entry Placeholder="ex: jtremblay"
                           Text="{Binding Name}"
                           PlaceholderColor="#AAAAAA"
                           TextColor="Black"
                           BackgroundColor="Transparent" />
                </Border>

                <Label Text="Courriel" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                <Border StrokeShape="RoundRectangle 40"
                        StrokeThickness="0.5"
                        Stroke="#AAAAAA"
                        BackgroundColor="White"
                        Padding="16,0">
                    <Entry Placeholder="votreemail@exemple.com"
                           Text="{Binding Email}"
                           Keyboard="Email"
                           PlaceholderColor="#AAAAAA"
                           TextColor="Black"
                           BackgroundColor="Transparent" />
                </Border>

                <Label Text="Mot de passe" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                <Border StrokeShape="RoundRectangle 40"
                        StrokeThickness="0.5"
                        Stroke="#AAAAAA"
                        BackgroundColor="White"
                        Padding="16,0">
                    <Entry Placeholder="••••••••"
                           Text="{Binding Password}"
                           IsPassword="True"
                           PlaceholderColor="#AAAAAA"
                           TextColor="Black"
                           BackgroundColor="Transparent" />
                </Border>

                <Label Text="Confirmer le mot de passe" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" />
                <Border StrokeShape="RoundRectangle 40"
                        StrokeThickness="0.5"
                        Stroke="#AAAAAA"
                        BackgroundColor="White"
                        Padding="16,0">
                    <Entry Placeholder="••••••••"
                           Text="{Binding ConfirmPassword}"
                           IsPassword="True"
                           PlaceholderColor="#AAAAAA"
                           TextColor="Black"
                           BackgroundColor="Transparent" />
                </Border>

                <Button Text="Créer le compte"
                        BackgroundColor="#134016"
                        TextColor="White"
                        CornerRadius="25"
                        FontAttributes="Bold"
                        HeightRequest="50"
                        Command="{Binding RegisterCommand}"
                        Margin="0,10,0,0" />

            </VerticalStackLayout>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Déjà un compte?" TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                <Label Text="Se connecter" TextColor="#134016" FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BackToLoginCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
