<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:BudgetTracker.Views"
       xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
       x:Class="BudgetTracker.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.TabBarBackgroundColor="{OnPlatform Android=#134016, iOS=White}"
       Shell.TabBarForegroundColor="{OnPlatform Android=White, iOS=#134016}"
       Shell.TabBarTitleColor="{OnPlatform Android=White, iOS=#134016}"
       Shell.TabBarUnselectedColor="{OnPlatform Android=#99FFFFFF, iOS=Gray}">

    <TabBar>
        <ShellContent Title="Accueil"
                      Route="Accueil"
                      Icon="{mi:FluentFilled Icon=Home24Filled}"
                      ContentTemplate="{DataTemplate views:HomePage}" />
        <ShellContent Title="Budget"
                      Route="Budget"
                      Icon="{mi:FluentFilled Icon=ClipboardTextLtr24Filled}"
                      ContentTemplate="{DataTemplate views:BudgetPage}" />
        <ShellContent Title="Transactions"
                      Route="Transactions"
                      Icon="{mi:FluentFilled Icon=Receipt24Filled}"
                      ContentTemplate="{DataTemplate views:TransactionsPage}" />
        <ShellContent Title="Statistiques"
                      Route="Statistiques"
                      Icon="{mi:FluentFilled Icon=ChartMultiple24Filled}"
                      ContentTemplate="{DataTemplate views:StatisticsPage}" />
    </TabBar>

    <!-- Registered routes for non-tab pages -->
</Shell>